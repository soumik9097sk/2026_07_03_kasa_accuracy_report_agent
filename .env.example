# Copy to .env and fill in. IMPORTANT: no spaces around "=" or python-dotenv
# loads the value under the wrong key and every LLM call fails.
GEMINI_API_KEY="your-key-here"

# Optional deployment overrides (defaults: <project-root>/data and <project-root>/output)
# KASA_DATA_DIR=/app/data
# KASA_OUTPUT_DIR=/app/output
# KASA_DATAMART_FILE=/app/data/amazon_all.csv
# KASA_FORECAST_FILE="/app/data/April Snapshot - May Forecasts with Actuals.xlsx"
